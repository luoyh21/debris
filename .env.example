# Space-Track（https://www.space-track.org/auth/createAccount）
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# OpenAI / LLM（AI 助手；不需要可留空）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

DB_HOST=localhost
DB_PORT=5432
DB_NAME=space_debris
DB_USER=postgres
DB_PASSWORD=postgres
# 仅改库密码时临时填写：库中仍是旧密码、.env 已是新密码时，同步脚本用其连接（改完可删）
# DB_PASSWORD_OLD=

SEGMENT_MINUTES=10
PROPAGATION_HORIZON_DAYS=3

# ESA DISCOS API（可选；https://discosweb.esoc.esa.int/ 注册）
ESA_DISCOS_TOKEN=
